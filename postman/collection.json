    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const email = \"user\" + Date.now() + \"@test.com\";\r",
                  "\r",
                  "pm.environment.set(\"email\", email);\r",
                  "\r",
                  "console.log(email);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"Test User\",\r\n  \"email\": \"{{email}}\",\r\n  \"password\": \"StrongPass123!\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "user",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "console.log(\"LOGIN TEST SCRIPT RUNNING1234\");\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "// Save token\r",
                  "pm.environment.set(\"token\", json.token);\r",
                  "\r",
                  "// Save user details\r",
                  "pm.environment.set(\"userId\", json.user.id);\r",
                  "pm.environment.set(\"userRole\", json.user.role);\r",
                  "\r",
                  "pm.test(\"Token exists\", function () {\r",
                  "    pm.expect(json.token).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"User role exists\", function () {\r",
                  "    pm.expect(json.user.role).to.exist;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"email\": \"{{adminEmail}}\",\r\n  \"password\": \"{{adminPassword}}\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "user",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
