        {
          "name": "Get All Shifts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "const json = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Shifts array exists\", function () {\r",
                  "    pm.expect(json.shifts).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"At least one shift exists\", function () {\r",
                  "    pm.expect(json.shifts.length).to.be.greaterThan(0);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Pagination exists\", function () {\r",
                  "    pm.expect(json.pagination).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Current page is returned\", function () {\r",
                  "    pm.expect(json.pagination.currentPage).to.exist;\r",
                  "});"
                ],
