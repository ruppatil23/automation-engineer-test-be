        {
          "name": "Create Shift",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "console.log(\"SCRIPT IS RUNNING1234\");\r",
                  "if (json?.shift?.id) {\r",
                  "    pm.environment.set(\"shiftId\", json.shift.id);\r",
                  "    console.log(\"SHIFT ID SAVED:\", json.shift.id);\r",
                  "} else {\r",
                  "    console.log(\"SHIFT ID NOT FOUND\", json);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
